# Coolify Environment Variables
# COPIAR A COOLIFY - NO SUBIR A GIT

# REQUIRED - Generate a new secret:
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_GENERATED_SECRET_KEY

# PostgreSQL - Use your existing password
POSTGRES_PASSWORD=YOUR_EXISTING_PASSWORD
POSTGRES_DB=confirming
POSTGRES_USER=postgres

# Frontend API URL
VITE_API_URL=https://api-confirming.egeadev.cloud

# Environment
ENVIRONMENT=production