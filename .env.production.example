# Production Environment Variables
# Coolify Deployment Configuration

# REQUIRED: Generate a secure secret key
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_secret_key_here

# Database - PostgreSQL connection string (configurar en Coolify)
DATABASE_URL=postgresql://postgres:your_password@10.0.89.74:5432/confirming

# PostgreSQL credentials (configurar en Coolify Database)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=confirming

# Frontend API URL -指向 backend en Coolify
VITE_API_URL=https://api-confirming.egeadev.cloud

# Optional: Error Tracking (Sentry)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Optional: Environment
ENVIRONMENT=production